# Normalize line endings: store text files with LF in the repo, check out
# with the platform's native EOL. https://git-scm.com/docs/gitattributes
* text=auto

# Enforce LF for files that should always be LF, regardless of platform.
*.py    text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf
.editorconfig   text eol=lf
LICENSE         text eol=lf

# Windows-specific scripts should stay CRLF.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary files: never modify.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
