{
  "_meta": {
    "description": "Numeric rank-to-measurement conversion tables for Mutants & Masterminds 4e. This data (the Ranks & Measures / Measurements Table and the Size Table) consists of game-functional numbers, not creative expression, so it's reproduced in full rather than paraphrased. Labels are the book's own display strings (e.g. '3.2 tons'); the numeric sibling fields (kg, lb, m, ft, seconds, m3, cft) are this project's own normalized conversions for programmatic use \u2014 they were not printed as such in the source and may carry small rounding differences from the book's approximate values.",
    "usageNote": "The book explicitly treats these as approximate, ballpark values, not precise conversions (see 'approximateNote'). Each rank actually represents a *range* of real-world measures; the listed value is roughly the midpoint/representative value for that rank. When converting a real-world value to a rank, round UP to the next rank if the value falls between two rows.",
    "approximateNote": "Values are guidelines, not precise physics. Don't over-index on exact conversions in play.",
    "doNotAddRanksNote": "Never add two ranks directly to combine measurements (e.g. distance rank 4 + distance rank 6 is NOT distance rank 10). Convert each rank to its real value, add the real values, then convert the sum back to the nearest rank.",
    "extrapolation": {
      "aboveRank30": "Each rank above 30 doubles (x2) the previous rank's value, for every measurement type.",
      "belowRankNeg5": "Each rank below -5 halves the previous (less negative) rank's value, for every measurement type."
    },
    "derivedFormulas": {
      "distanceFromSpeedAndTime": "distance_rank = time_rank + speed_rank  (how far you travel at a given speed over a given time)",
      "timeFromSpeedAndDistance": "time_rank = distance_rank - speed_rank  (how long it takes to cover a distance at a given speed)",
      "throwingDistance": "throwing_distance_rank = strength_rank - object_mass_rank  (how far you can throw something)",
      "note": "A character's ground Speed rank corresponds to the Distance rank they cover in one round (time rank 0, i.e. 6 seconds) \u2014 e.g. Speed rank 2 covers distance rank 2 (30 ft / 8 m) per round."
    },
    "sizeTableColumns": {
      "sizeRank": "Roughly the character's height/length on the distance column of the measurements table",
      "spaces": "How much room (in Spaces) the character needs to move unhindered at this size",
      "reach": "Close-attack range in Spaces",
      "defenseMod": "Modifier to the character's Defense Power Level limit at this size",
      "damageMod": "Modifier to the character's Damage/Strength rank Power Level limit at this size",
      "toughnessMod": "Modifier to the character's Toughness Power Level limit at this size",
      "speedMod": "Modifier to ground movement speed rank at this size",
      "intimidationMod": "Modifier to Intimidation skill checks at this size",
      "stealthMod": "Modifier to Stealth skill checks at this size"
    }
  },
